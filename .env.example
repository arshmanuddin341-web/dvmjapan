# Database – PostgreSQL (use Docker: docker-compose up -d)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tradeware"

# Optional: Cloud PostgreSQL (Neon / Supabase / Railway) – replace above with their URL
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT secret - generate a random string for production
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Super admin login (Vercel) – set in Vercel → Settings → Environment Variables
# SUPER_ADMIN_EMAIL=karim@tradewaregroup.com
# SUPER_ADMIN_PASSWORD=Admin1234

# Backend API (Express) - required for login/register/auth
NEXT_PUBLIC_API_URL=http://localhost:5000
BACKEND_URL=http://localhost:5000

# Real-time broadcast (optional; falls back to JWT_SECRET)
# REALTIME_BROADCAST_SECRET=your-broadcast-secret

# Show Google/Facebook login buttons (set to "true" only after OAuth is set up in Google Console)
# NEXT_PUBLIC_SHOW_GOOGLE_LOGIN=true

# ---- Cloudinary (Admin → Add Vehicle image upload) – set in Vercel for production ----
# Get from https://cloudinary.com dashboard (free tier) → Dashboard shows Cloud name, API Key, API Secret
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
# NEXT_PUBLIC_CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# WhatsApp floating button (green icon on every page, above chatbot & calculator)
# Number with country code, no + or spaces, e.g. 923001234567
# NEXT_PUBLIC_WHATSAPP_NUMBER=923001234567

# Japan auction LIVE data (optional – without these, demo data is used)
# JAPAN_AUCTION_API_URL=https://your-api.com/japan
# JAPAN_AUCTION_API_KEY=your-api-key-if-required
# JAPAN_AUCTION_AVTOJP_CODE=your_avtojp_code
